// ════════════════════════════════════════════════════════════════════════════
// 支付模块 schema (M2) —— Stripe / 微信 / 支付宝 + 订单/合约/退款/订阅
// 不需要支付：删本文件 + 删 00-core.prisma 中 User 上「支付模块关系」整段。
// ════════════════════════════════════════════════════════════════════════════

model Product {
  id          String   @id @default(cuid())
  code        String   @unique                 // STANDARD | AI | AI_UNLIMITED
  name        String
  plan        String                            // User.plan target value
  active      Boolean  @default(true)
  prices      Price[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Price {
  id                String         @id @default(cuid())
  productId         String
  product           Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  code              String         @unique      // STANDARD_1M | STANDARD_12M | AI_1M | ...
  name              String?
  months            Int                           // 1 | 3 | 12
  currency          String         @default("CNY")
  amountCents       Int
  supportsAutoRenew Boolean        @default(false) // typically only monthly prices
  active            Boolean        @default(true)
  stripePriceId     String?
  stripeMappings    PriceStripeMapping[]
  orders            PaymentOrder[]
  contracts         PayContract[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([productId, months, currency])
  @@index([productId, active])
}

model PriceStripeMapping {
  id           String   @id @default(cuid())
  priceId      String
  price        Price    @relation(fields: [priceId], references: [id], onDelete: Cascade)
  currency     String
  stripePriceId String  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([priceId, currency])
  @@index([currency])
}

model PaymentOrder {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider         String    // wechat | alipay | stripe
  product          String    // native_qr | page_pay | precreate_qr | autopay | stripe_checkout | stripe_subscription

  plan             String
  months           Int       @default(1)

  priceId          String?
  price            Price?    @relation(fields: [priceId], references: [id])

  contractId       String?
  contract         PayContract? @relation(fields: [contractId], references: [id])

  currency         String    @default("CNY")
  amountCents      Int

  status           String    @default("CREATED") // CREATED | PENDING | PAID | CLOSED | REFUNDED | FAILED
  externalTradeNo  String?   // transaction_id / trade_no
  providerOrderNo  String?   // out_trade_no
  refundedCents    Int       @default(0)

  codeUrl          String?
  redirectUrl      String?

  paidAt           DateTime?
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  refunds          RefundOrder[]

  @@unique([provider, providerOrderNo])
  @@index([userId, createdAt])
  @@index([provider, status, createdAt])
  @@index([providerOrderNo])
  @@index([contractId])
}

model PayContract {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  priceId             String
  price               Price     @relation(fields: [priceId], references: [id])

  provider            String                    // wechat | alipay | stripe
  externalContractId  String    @unique         // wechat contract_id / alipay agreement_no / stripe sub id mirror

  stripeCustomerId      String?
  stripeSubscriptionId  String?  @unique

  status              String    @default("PENDING") // PENDING | ACTIVE | TERMINATED | SUSPENDED
  nextChargeAt        DateTime?
  lastChargeAt        DateTime?
  failedCount         Int       @default(0)
  signedAt            DateTime?
  terminatedAt        DateTime?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  orders              PaymentOrder[]

  @@index([status, nextChargeAt])
  @@index([userId, status])
}

model RefundOrder {
  id               String        @id @default(cuid())
  orderId          String
  order            PaymentOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amountCents      Int
  reason           String?
  status           String        @default("PENDING") // PENDING | SUCCEEDED | FAILED
  externalRefundNo String?       @unique
  operatorAdminId  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([orderId, status])
}

model Subscription {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan            String
  status          String    @default("ACTIVE") // ACTIVE | CANCELLED | EXPIRED
  startedAt       DateTime  @default(now())
  currentPeriodEnd DateTime

  autoRenew       Boolean   @default(false)
  provider        String?   // wechat | alipay
  contractId      String?   // agreement/contract identifier
  nextChargeAt    DateTime?

  sourceOrderId   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, status])
  @@index([autoRenew, nextChargeAt])
}
