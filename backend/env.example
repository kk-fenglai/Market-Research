# 复制本文件为 .env 后填值：  cp env.example .env
# （.env 已被 .gitignore 忽略，切勿提交真实密钥）

# ─── Server ────────────────────────────────────────────────────────────────
PORT=4000
# development | production   (production enforces stricter env checks)
NODE_ENV=development
# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ─── Database (PostgreSQL — 推荐 Neon 免费档) ───────────────────────────────
# 从 https://console.neon.tech 拿连接串（必须含 sslmode=require）。
# Neon 用 *Direct* host（不带 "-pooler"）—— pooler 会让 prisma migrate 失败。
DATABASE_URL="postgresql://USER:PASS@HOST/dbname?sslmode=require"

# ─── Frontend URL (CORS + 邮件链接) ────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── JWT secrets (必填, 各 32+ 字符, 两个必须不同) ──────────────────────────
# 生成：  openssl rand -hex 48
JWT_ACCESS_SECRET=REPLACE_WITH_openssl_rand_hex_48
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_openssl_rand_hex_48
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=14d
JWT_ADMIN_ACCESS_EXPIRES=30m
JWT_ADMIN_REFRESH_EXPIRES=2h

# ─── Admin bootstrap ───────────────────────────────────────────────────────
# 仅首次 `npm run seed` 用，首次登录后立刻改密。需满足密码策略(≥10 位, 3 类字符)。
ADMIN_INITIAL_PASSWORD=CHANGE_ME_On_First_Login_2026!
# 可选：允许访问 /api/admin/* 的 IP 白名单（生产强烈建议）
# ADMIN_IP_ALLOWLIST=203.0.113.10,198.51.100.25

# ─── SMTP (生产必填 — 邮箱验证 / 2FA / 找回密码) ────────────────────────────
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@example.com
# 163 邮箱填「授权码」而非登录密码
SMTP_PASS=YOUR_SMTP_AUTHORIZATION_CODE
SMTP_FROM=market-research <you@example.com>

# ─── 支付：M2 模块 (Stripe 默认主通道) ──────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...        # embedded checkout 需要
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_ANCHOR_CURRENCY=EUR
# STRIPE_CHECKOUT_UI=embedded               # embedded(默认) | hosted
# STRIPE_CHECKOUT_SUCCESS_URL=              # 仅 hosted 模式用
# STRIPE_CHECKOUT_CANCEL_URL=
#
# 国内直连通道默认关闭；需中国大陆商户号 + ICP 备案回调域名才开。
ENABLE_DIRECT_WECHAT=false
ENABLE_DIRECT_ALIPAY=false
# PAY_PUBLIC_BASE_URL=https://api.your-domain.com
# WECHAT_MCHID=
# WECHAT_SERIAL_NO=
# WECHAT_APIV3_KEY=
# WECHAT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# WECHAT_PLATFORM_CERT_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# WECHAT_PAPAY_PLAN_ID=
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# ALIPAY_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# ALIPAY_PERIOD_RULE_JSON={"period_type":"MONTH","period":1,"execute_time":"2026-01-01"}

# ════════════════════════════════════════════════════════════════════════════
# ↓↓↓ 业务示例 (business-delf) 专用 env —— 换业务时按需删除/替换 ↓↓↓
# ════════════════════════════════════════════════════════════════════════════
# 听力音频 CDN（可选）
# AUDIO_CDN_ORIGIN=https://cdn.example.com
# AUDIO_CDN_REPLACE_FROM=https://pub-xxxx.r2.dev
# AI 批改：DeepSeek（必填于该业务） https://platform.deepseek.com/api_keys (≥30 字符)
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# Qwen / DashScope（可选，仅 Qwen 档位用）
# DASHSCOPE_API_KEY=
# 口语 AI：Whisper STT + DeepSeek。需 OPENAI_API_KEY(Whisper)。
# OPENAI_API_KEY=
# ENABLE_ORAL_AI=false
# 本地后台 worker：当 DATABASE_URL 指向生产 Neon 时设 false，避免抢生产任务
# RUN_BG_WORKERS=false
# 免费试用（无支付，给新验证用户 AI_UNLIMITED）
# TRIAL_ENABLED=true
# TRIAL_DAYS=3
# TRIAL_PLAN=AI_UNLIMITED
# ════════════════════════════════════════════════════════════════════════════

# 生产保持 false。设 true 才允许 `npm run seed` 建弱密码 demo 账号。客户站点切勿开。
ALLOW_PROD_SEED=false
